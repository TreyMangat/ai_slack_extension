# --- Feature Factory (Local) ---
APP_ENV=local
MOCK_MODE=true

# Base URL for links shown in Slack / UI
BASE_URL=http://localhost:8000
# Internal URL used by the slackbot container to reach the API
ORCHESTRATOR_INTERNAL_URL=http://api:8000


# --- Database / Queue ---
DATABASE_URL=postgresql+psycopg2://feature:feature@db:5432/feature_factory
REDIS_URL=redis://redis:6379/0

# --- Security ---
# Used to sign internal tokens/callbacks (keep secret in real deployments)
SECRET_KEY=dev-change-me

# --- Slack (optional) ---
# If you want Slack integration, set ENABLE_SLACK_BOT=true and provide tokens.
# For first-time local testing, leave disabled and use the web UI.
ENABLE_SLACK_BOT=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=

# Restrict who can use the bot (recommended). Comma-separated.
SLACK_ALLOWED_CHANNELS=
SLACK_ALLOWED_USERS=
SLACK_REQUIRE_MENTION=true
# Reviewer/admin approvals (optional but recommended in team settings)
REVIEWER_ALLOWED_USERS=
REVIEWER_CHANNEL_ID=

# --- GitHub (optional) ---
GITHUB_ENABLED=false
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_API_BASE=https://api.github.com
GITHUB_DEFAULT_BRANCH=main

# When GitHub is enabled, we create an issue and post this comment to trigger OpenCode.
# (You must install the OpenCode GitHub Action in the target repo for this to work.)
OPENCODE_TRIGGER_COMMENT=/oc Implement this issue. Follow the acceptance criteria. Add tests.

# --- Policy ---
# If true, auto-merge is disabled no matter what.
DISABLE_AUTOMERGE=true
# Optional API auth token. If set, mutating /api routes require X-FF-Token header.
API_AUTH_TOKEN=

# --- Integration callbacks (CI/OpenCode -> orchestrator) ---
# Required for signed callbacks to /api/integrations/execution-callback
INTEGRATION_WEBHOOK_SECRET=dev-webhook-secret
# Reject callback signatures older than this many seconds.
INTEGRATION_WEBHOOK_TTL_SECONDS=300

# --- Workspace isolation / source-repo snapshots ---
# Worker prepares an isolated workspace per build.
WORKSPACE_ROOT=/tmp/feature_factory_workspaces
# For safety this is off by default. Enable to allow git clone snapshots.
WORKSPACE_ENABLE_GIT_CLONE=false
WORKSPACE_MAX_SOURCE_REPOS=5
WORKSPACE_GIT_CLONE_TIMEOUT_SECONDS=120
# Local path copies must be inside this root.
WORKSPACE_LOCAL_COPY_ROOT=/app
# Comma-separated paths to skip while copying local snapshots.
WORKSPACE_COPY_IGNORE=.git,.venv,node_modules,__pycache__,.pytest_cache,.mypy_cache
# Cleanup retention for old workspace directories.
WORKSPACE_RETENTION_HOURS=24
WORKSPACE_CLEANUP_MAX_PER_RUN=50
# Status-aware retention policy:
# - with PR: keep longer for review/audit
WORKSPACE_RETENTION_HOURS_WITH_PR=168
# - without PR: shorter retention for drafts/non-promoted work
WORKSPACE_RETENTION_HOURS_WITHOUT_PR=24
# - failed/needs-info states: shortest retention
WORKSPACE_RETENTION_HOURS_FAILED=12
