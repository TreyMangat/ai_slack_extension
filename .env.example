# --- Feature Factory (Local) ---
APP_ENV=local
MOCK_MODE=true
ENFORCE_PRODUCTION_SECURITY=true
ENABLE_API_DOCS=true
ENABLE_API_DOCS_IN_PROD=false
RUN_MIGRATIONS=false
# One-time bootstrap option for existing databases created before Alembic was introduced.
MIGRATION_BOOTSTRAP_STAMP=false

# Base URL for links shown in Slack / UI
BASE_URL=http://localhost:8000
# Internal URL used by the slackbot container to reach the API
ORCHESTRATOR_INTERNAL_URL=http://api:8000

# --- Deployment / edge auth posture ---
# AUTH_MODE:
# - disabled: local/dev convenience (no auth enforcement)
# - api_token: require X-FF-Token
# - edge_sso: trust identity headers from edge auth proxy (oauth2-proxy / Cloudflare Access)
AUTH_MODE=disabled
SSO_PROVIDER=
IDP=
HOSTING_TARGET=local
AUTH_HEADER_EMAIL=X-Forwarded-Email
AUTH_HEADER_GROUPS=X-Forwarded-Groups
AUTH_SERVICE_ACTOR_HEADER=X-Feature-Factory-Actor
# Service-token requests (X-FF-Token) are assigned these groups for internal automations (slackbot/worker integrations).
SERVICE_AUTH_GROUPS=engineering,admins
# RBAC rules (comma-separated OR logic). Supported entries:
# - any_authenticated
# - group:<name>
# - user:<identity>
RBAC_REQUESTERS=any_authenticated
RBAC_BUILDERS=group:engineering
RBAC_APPROVERS=group:admins


# --- Database / Queue ---
DATABASE_URL=postgresql+psycopg2://feature:feature@db:5432/feature_factory
REDIS_URL=redis://redis:6379/0
# Optional aliases for hosted providers (deploy script can map these):
NEONURL=
UPSTASH_REDIS_URL=

# --- Security ---
# Used to sign internal tokens/callbacks (keep secret in real deployments)
SECRET_KEY=dev-change-me

# --- Slack (optional) ---
# If you want Slack integration, set ENABLE_SLACK_BOT=true and provide tokens.
# For first-time local testing, leave disabled and use the web UI.
ENABLE_SLACK_BOT=false
# Slack runtime mode:
# - socket: separate slackbot process (local/docker profile)
# - http: Slack Events API endpoint served by FastAPI at /api/slack/events (recommended for Modal/cloud)
SLACK_MODE=socket
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=

# Restrict who can use the bot (recommended). Comma-separated.
SLACK_ALLOWED_CHANNELS=
SLACK_ALLOWED_USERS=
SLACK_REQUIRE_MENTION=true
# Reviewer/admin approvals (optional but recommended in team settings)
REVIEWER_ALLOWED_USERS=
REVIEWER_CHANNEL_ID=

# --- GitHub (optional) ---
GITHUB_ENABLED=false
GITHUB_AUTH_MODE=token
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_JWT_TTL_SECONDS=540
# Optional convenience for install/login guidance when app is missing on a repo:
GITHUB_APP_SLUG=
GITHUB_APP_INSTALL_URL=
# Optional global fallback repo (recommended flow is per-request `spec.repo`):
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_API_BASE=https://api.github.com
GITHUB_DEFAULT_BRANCH=main

# Code runner mode:
# - opencode: run local OpenClaw in worker and open PR directly (default)
# - native_llm: in-container LLM coding loop (experimental)
CODERUNNER_MODE=opencode
# For CODERUNNER_MODE=opencode:
# - local_openclaw: worker executes OpenClaw directly (no API key; uses mounted OAuth auth)
OPENCODE_EXECUTION_MODE=local_openclaw
# OpenClaw auth directory inside containers (mount ./secrets/openclaw here)
OPENCLAW_AUTH_DIR=/home/app/.openclaw
# Read-only seed directory mounted from host secrets
OPENCLAW_AUTH_SEED_DIR=/run/secrets/openclaw
# Model identifier for local OpenClaw execution
OPENCODE_MODEL=openai-codex/gpt-5.3-codex
# Max seconds allowed for one OpenClaw coding turn
OPENCODE_TIMEOUT_SECONDS=1800
# Keep temp agents for debugging (false recommended)
OPENCODE_KEEP_TEMP_AGENTS=false
# Deterministic pipeline probe: create DEBUG_CODEGEN.md instead of model execution
OPENCODE_DEBUG_BUILD=false
# Preview provider metadata for PR instructions
# - cloudflare_pages (recommended)
# - github_pages (fallback)
PREVIEW_PROVIDER=cloudflare_pages
CLOUDFLARE_PAGES_PROJECT_NAME=
CLOUDFLARE_PAGES_PRODUCTION_BRANCH=main

# Native LLM runner (used when CODERUNNER_MODE=native_llm and MOCK_MODE=false)
LLM_PROVIDER=openai
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2
LLM_MAX_PATCH_ROUNDS=3
LLM_REPO_MAX_FILES=250
LLM_REPO_FILE_MAX_CHARS=5000
# Optional install/bootstrap command before tests (examples: "pip install -r requirements-dev.txt", "npm ci")
LLM_INSTALL_COMMAND=
# Command used to validate generated code in the target repo workspace
LLM_TEST_COMMAND=pytest -q
LLM_PUSH_BRANCH_PREFIX=feature-factory
LLM_COMMIT_AUTHOR_NAME=feature-factory-bot
LLM_COMMIT_AUTHOR_EMAIL=feature-factory-bot@local.invalid

# --- Policy ---
# If true, auto-merge is disabled no matter what.
DISABLE_AUTOMERGE=true
# Optional API auth token. If set, mutating /api routes require X-FF-Token header.
API_AUTH_TOKEN=

# --- Integration callbacks (CI/OpenCode -> orchestrator) ---
# Required for signed callbacks to /api/integrations/execution-callback
INTEGRATION_WEBHOOK_SECRET=dev-webhook-secret
# Reject callback signatures older than this many seconds.
INTEGRATION_WEBHOOK_TTL_SECONDS=300
# Alert if a feature remains PR_OPENED without callback for this long.
CALLBACK_STALE_ALERT_MINUTES=30
# Re-alert cooldown for the same feature.
CALLBACK_STALE_ALERT_COOLDOWN_MINUTES=60
# Maximum PR_OPENED rows scanned per cleanup cycle.
CALLBACK_STALE_CHECK_MAX_PER_RUN=50

# --- Workspace isolation / source-repo snapshots ---
# Worker prepares an isolated workspace per build.
WORKSPACE_ROOT=/tmp/feature_factory_workspaces
# For safety this is off by default. Enable to allow git clone snapshots.
WORKSPACE_ENABLE_GIT_CLONE=false
WORKSPACE_MAX_SOURCE_REPOS=5
WORKSPACE_GIT_CLONE_TIMEOUT_SECONDS=120
# Local path copies must be inside this root.
WORKSPACE_LOCAL_COPY_ROOT=/app
# Comma-separated paths to skip while copying local snapshots.
WORKSPACE_COPY_IGNORE=.git,.venv,node_modules,__pycache__,.pytest_cache,.mypy_cache
# Cleanup retention for old workspace directories.
WORKSPACE_RETENTION_HOURS=24
WORKSPACE_CLEANUP_MAX_PER_RUN=50
WORKSPACE_CLEANUP_INTERVAL_MINUTES=60
# Status-aware retention policy:
# - with PR: keep longer for review/audit
WORKSPACE_RETENTION_HOURS_WITH_PR=168
# - without PR: shorter retention for drafts/non-promoted work
WORKSPACE_RETENTION_HOURS_WITHOUT_PR=24
# - failed/needs-info states: shortest retention
WORKSPACE_RETENTION_HOURS_FAILED=12

# --- Modal runtime cost controls (optional; used by modal_app.py) ---
# Scale API to zero when idle (lowest cost, with cold starts).
MODAL_API_MIN_CONTAINERS=0
MODAL_API_MAX_CONTAINERS=1
MODAL_API_ALLOW_CONCURRENT_INPUTS=8
# How often Modal invokes one-shot workers.
MODAL_QUEUE_DRAIN_SECONDS=180
MODAL_CLEANUP_INTERVAL_MINUTES=120
# Skip booting RQ worker when default queue is empty.
MODAL_SKIP_WORKER_WHEN_QUEUE_EMPTY=true
# Modal secret name consumed at deploy-time by modal_app.py.
MODAL_ENV_SECRET_NAME=feature-factory-env
# Additional Modal secret names (comma-separated), e.g. slack-secret.
MODAL_EXTRA_SECRET_NAMES=
# Bundle local OpenClaw auth into Modal image during deploy (required for opencode local_openclaw on Modal).
MODAL_INCLUDE_OPENCLAW_AUTH=false
MODAL_OPENCLAW_AUTH_LOCAL_DIR=secrets/openclaw
